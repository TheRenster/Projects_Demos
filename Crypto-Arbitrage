def submit_order(symbol, qty, side):
    order_data = MarketOrderRequest(
        symbol=symbol,
        qty=qty,
        side=side,
        time_in_force=TimeInForce.GTC
    )
    try:
        order = trading_client.submit_order(order_data=order_data)
        print(f"Order submitted: {order}")
    except Exception as e:
        print(f"Failed to submit order for {symbol}: {e}")

def place_orders(orders):
    # Use ThreadPoolExecutor to submit orders concurrently
    with concurrent.futures.ThreadPoolExecutor() as executor:
        futures = [executor.submit(submit_order, orders[order].symbol, orders[order].qty, orders[order].side) for order in orders.keys()]
        for future in concurrent.futures.as_completed(futures):
            future.result()  # Wait for all futures to complete

