def create_orders(path, initial_quantity,g):
    """
    Creates a dictionary of alternating sell and buy orders for a given path of cryptocurrencies.

    Parameters:
    - path (list of tuples): Each tuple contains (coin_symbol, edge_weight).
      - coin_symbol (str): The symbol of the cryptocurrency (e.g., 'BTCUSD').
      - edge_weight (float): The exchange rate to the next coin in the path.
    - initial_quantity (float): The quantity of the first coin to sell.

    Returns:
    - dict: A dictionary where keys are order symbols and values are MarketOrderRequest objects.
    """
    orders = {}
    quantity = initial_quantity

    for i in range(len(path) - 1):
        current_coin = path[i]
        next_coin = path[i + 1]
        edge_weight = g[current_coin][next_coin].get("weight",1)
        # Determine the side of the order
        if i % 2 == 0:
            # Sell current_coin
            side = OrderSide.SELL
            symbol = f'{current_coin.upper()}/USD'
        else:
            # Buy next_coin
            side = OrderSide.BUY
            symbol = f'{next_coin.upper()}/USD'
            # Adjust quantity for the next buy order
        
        # Create a market order request
        order = MarketOrderRequest(
            symbol=symbol,
            qty=quantity,
            side=side,
            time_in_force=TimeInForce.GTC
        )
        quantity *= edge_weight * 0.99  # Apply safety margin
        # Add the order to the dictionary
        orders[symbol] = order

    return orders

